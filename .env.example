# Smartlead
SMARTLEAD_API_KEY=

# Client Smartlead accounts used by scripts/client_export.py (LinkedIn outreach
# export) — separate from the main app's own SMARTLEAD_API_KEY above
AERODEFENSE_SMARTLEAD_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Cheap model used only for on-demand thread translation (not draft writing)
ANTHROPIC_TRANSLATE_MODEL=claude-haiku-4-5

# Dashboard auth (single shared password) + session signing key
APP_PASSWORD=
SECRET_KEY=change-me-to-a-random-string

# n8n webhook URL that posts the "lead replied" Slack notification
N8N_WEBHOOK_URL=

# Shared secret Smartlead sends back on webhook calls (set the same value when
# registering the webhook in Smartlead); leave blank to skip verification
SMARTLEAD_WEBHOOK_SECRET=

# Public URL this app is reachable at (used to build dashboard links in Slack notifications)
PUBLIC_BASE_URL=https://sdr.yourdomain.com

# Cloudflare Tunnel token (docker-compose reads this for the cloudflared service)
CLOUDFLARE_TUNNEL_TOKEN=

# Where the SQLite DB lives inside the container (matches the docker-compose volume)
DB_PATH=/data/responder.db

# Images pasted/dropped into a draft are stored here and served publicly at
# PUBLIC_BASE_URL/i/<name> (same volume as the DB, so they survive a redeploy).
# PUBLIC_BASE_URL must be the real, externally reachable URL — the recipient's
# mail client fetches the image from it.
UPLOAD_DIR=/data/uploads

# Safety switches
DRY_RUN=true
AUTO_SEND_FOLLOWUPS=false
# Pre-generate every due follow-up draft right after the daily scan via the
# Anthropic Batch API (50% token cost, results within ~1h) so the morning
# dashboard is a ready review queue. Generation only — sending still requires
# a click unless AUTO_SEND_FOLLOWUPS is also on.
AUTO_GENERATE_FOLLOWUPS=true

# Follow-up policy
INTERESTED_CATEGORY_NAME=Interested
# Smartlead auto-classifies auto-reply/out-of-office bounces under this category;
# leads here get a short "please forward this" nudge instead of the normal pipeline
AUTOREPLY_CATEGORY_NAME=Auto-Reply
# Smartlead category that marks a booked meeting — freezes all outreach for the
# lead and feeds the Stats view (matched ignoring case/punctuation)
MEETING_BOOKED_CATEGORY_NAME=Meeting-Booked
# Days before follow-up #1, #2, ... — a comma list spaces touches out as the
# thread goes colder (last value repeats); a single number keeps a fixed cadence
FOLLOWUP_WAIT_DAYS=3,4,6,8
MAX_FOLLOWUPS=4
# After the cap, quietly resurface a cold lead for one revival touch every N
# days of silence (0 disables)
REVIVE_AFTER_DAYS=60
DAILY_SCAN_HOUR_UTC=6

CALENDLY_LINK=https://calendly.com/andrew-mindaptive/30min
